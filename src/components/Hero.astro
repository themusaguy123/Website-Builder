---
interface Props {
  variant?: 'home' | 'service' | 'location' | 'contact';
  headline: string;
  subheadline: string;
  phone?: string;
  phoneHref?: string;
  badge?: string;
  showPhoneGroup?: boolean;
}

const {
  variant = 'home',
  headline,
  subheadline,
  badge,
  showPhoneGroup = false,
} = Astro.props;
---

<section class={`hero hero--${variant}`}>
  <div class="container hero-inner">

    {/* Image panel — home only. Sits above the text via CSS order. */}
    {variant === 'home' && (
      <div class="hero-image-wrap" aria-hidden="true">
        <div class="hero-image-container">
          <img
            src="/images/van/hero-van.jpg"
            alt="DMV Appliance Repair service van"
            class="hero-image"
            width="800"
            height="450"
            loading="eager"
            fetchpriority="high"
            onerror="this.parentElement.classList.add('hero-image-placeholder')"
          />
          <div class="hero-image-fallback">
            <img
              src="/images/logos/logo-header.svg"
              alt="DMV Appliance Repair"
              class="hero-logo-fallback"
              width="260"
              height="67"
            />
            <p class="hero-placeholder-text">Serving the DMV since 2007</p>
          </div>
        </div>
        <div class="hero-badge-float">
          <span class="badge badge--accent">Same-day available</span>
          <span class="hero-badge-sub">7 days a week</span>
        </div>
      </div>
    )}

    <div class="hero-content">
      {badge && (
        <div class="hero-badge">
          <span class="badge badge--soft">{badge}</span>
        </div>
      )}

      <h1 class="hero-headline">{headline}</h1>
      <p class="hero-sub">{subheadline}</p>

      <div class="hero-actions">
        {variant === 'home' ? (
          <>
            <div class="hero-cta-primary">
              <a href="tel:+17038667776" class="btn btn--primary hero-call-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24c1.12.37 2.33.57 3.57.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.45.57 3.57a1 1 0 0 1-.25 1.02l-2.2 2.2z" fill="currentColor"/>
                </svg>
                Call 703-866-7776
              </a>
              <a href="#booking" class="btn btn--outline hero-form-link">Request a Callback</a>
            </div>
            <p class="hero-alt-numbers">
              DC: <a href="tel:+12027832055" class="hero-alt-link">202-783-2055</a>
              &nbsp;·&nbsp;
              MD: <a href="tel:+13019076666" class="hero-alt-link">301-907-6666</a>
            </p>
          </>
        ) : (
          <div class="hero-cta-row">
            <a href="#booking" class="btn btn--primary">Request a Callback</a>
            <a href="tel:+17038667776" class="btn btn--outline">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24c1.12.37 2.33.57 3.57.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.45.57 3.57a1 1 0 0 1-.25 1.02l-2.2 2.2z" fill="currentColor"/>
              </svg>
              703-866-7776
            </a>
          </div>
        )}
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    background-color: var(--color-slate);
    color: #fff;
    padding-block: var(--space-16) var(--space-14);
    overflow: hidden;
  }

  /* ─── Default inner grid (service / location / contact) ─── */
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  /* ─── Home: single stacked column, image on top ─── */
  .hero--home .hero-inner {
    max-width: 800px;
    margin-inline: auto;
    gap: 0; /* handled by margin-bottom on image-wrap */
  }

  /* Image above content */
  .hero--home .hero-image-wrap {
    margin-bottom: var(--space-10);
    order: -1; /* appears above .hero-content in the DOM */
  }

  .hero--home .hero-content {
    max-width: 680px;
  }

  /* Hero image */
  .hero-image-wrap {
    position: relative;
    opacity: 0;
    animation: heroFadeIn 0.55s var(--ease-out) 0s forwards;
  }

  .hero-image-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background-color: rgba(255,255,255,0.06);
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-image-fallback {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-5);
    width: 100%;
    height: 100%;
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.01) 100%);
  }

  .hero-image-placeholder .hero-image { opacity: 0; }
  .hero-image-placeholder .hero-image-fallback { display: flex; }

  .hero-logo-fallback {
    width: 260px;
    height: auto;
    opacity: 0.9;
  }

  .hero-placeholder-text {
    font-size: var(--font-small);
    color: rgba(255,255,255,0.38);
    letter-spacing: 0.05em;
    max-width: none;
  }

  .hero-badge-float {
    position: absolute;
    bottom: var(--space-4);
    right: var(--space-4);
    background-color: var(--color-slate);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--radius-md);
    padding: 0.5rem 0.875rem;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .hero-badge-sub {
    font-size: var(--font-xs);
    color: rgba(255,255,255,0.55);
  }

  /* Hero content */
  .hero-content {
    max-width: 640px;
  }

  .hero-badge {
    margin-bottom: var(--space-4);
    opacity: 0;
    animation: heroFadeIn 0.4s var(--ease-out) 0.12s forwards;
  }

  .hero-headline {
    color: #fff;
    font-size: var(--font-hero);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-5);
    opacity: 0;
    animation: heroFadeIn 0.5s var(--ease-out) 0.18s forwards;
  }

  .hero-sub {
    font-size: clamp(1rem, 1.5vw + 0.5rem, 1.125rem);
    line-height: 1.65;
    color: rgba(255,255,255,0.7);
    margin-bottom: var(--space-8);
    max-width: 52ch;
    opacity: 0;
    animation: heroFadeIn 0.5s var(--ease-out) 0.26s forwards;
  }

  .hero-actions {
    opacity: 0;
    animation: heroFadeIn 0.5s var(--ease-out) 0.34s forwards;
  }

  /* Home CTA row */
  .hero-cta-primary {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-3);
  }

  .hero-call-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .hero-form-link {
    color: rgba(255,255,255,0.75);
    border-color: rgba(255,255,255,0.2);
    font-size: var(--font-small);
  }

  @media (hover: hover) and (pointer: fine) {
    .hero-form-link:hover {
      color: #fff;
      border-color: rgba(255,255,255,0.4);
      background-color: rgba(255,255,255,0.08);
    }
  }

  /* Alt numbers (DC / MD) */
  .hero-alt-numbers {
    font-size: var(--font-xs);
    color: rgba(255,255,255,0.4);
    max-width: none;
  }

  .hero-alt-link {
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    transition: color var(--duration-base) var(--ease-out);
  }

  @media (hover: hover) and (pointer: fine) {
    .hero-alt-link:hover { color: rgba(255,255,255,0.85); }
  }

  /* Non-home CTA row */
  .hero-cta-row {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    align-items: center;
  }

  .hero-cta-row .btn--outline {
    color: rgba(255,255,255,0.75);
    border-color: rgba(255,255,255,0.2);
  }

  @media (hover: hover) and (pointer: fine) {
    .hero-cta-row .btn--outline:hover {
      color: #fff;
      background-color: rgba(255,255,255,0.08);
      border-color: rgba(255,255,255,0.35);
    }
  }

  /* Service / location / contact overrides */
  .hero--service,
  .hero--location,
  .hero--contact {
    padding-block: var(--space-12) var(--space-10);
  }

  .hero--service .hero-inner,
  .hero--location .hero-inner,
  .hero--contact .hero-inner {
    max-width: var(--max-width-text);
  }

  .hero--service .hero-headline,
  .hero--location .hero-headline,
  .hero--contact .hero-headline {
    font-size: var(--font-h2);
  }

  /* Keyframes */
  @keyframes heroFadeIn {
    from {
      opacity: 0;
      transform: translateY(10px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-badge,
    .hero-headline,
    .hero-sub,
    .hero-actions,
    .hero-image-wrap {
      animation: none;
      opacity: 1;
    }
  }

  /* Mobile */
  @media (max-width: 600px) {
    .hero--home .hero-image-wrap {
      margin-bottom: var(--space-8);
    }
  }
</style>
