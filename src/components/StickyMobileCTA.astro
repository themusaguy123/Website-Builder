---
// Sticky bottom bar — mobile only (≤768px)
// Hides on scroll-up, returns on scroll-down
---

<div class="sticky-cta" id="sticky-cta" aria-label="Quick contact bar" role="complementary">
  <a href="tel:+17038667776" class="sticky-btn sticky-btn--call">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24c1.12.37 2.33.57 3.57.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.45.57 3.57a1 1 0 0 1-.25 1.02l-2.2 2.2z" fill="currentColor"/>
    </svg>
    Call Now
  </a>
  <a href="#booking" class="sticky-btn sticky-btn--form">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    Request Callback
  </a>
</div>

<style>
  .sticky-cta {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 90;
    background-color: var(--color-slate);
    border-top: 1px solid rgba(255,255,255,0.1);
    padding: var(--space-3) var(--space-4);
    padding-bottom: calc(var(--space-3) + env(safe-area-inset-bottom, 0));
    transform: translateY(0);
    transition: transform var(--duration-base) var(--ease-out);
  }

  /* Only show on mobile */
  @media (max-width: 768px) {
    .sticky-cta {
      display: flex;
      gap: var(--space-3);
    }
  }

  .sticky-cta.hidden {
    transform: translateY(100%);
  }

  .sticky-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: 0.75rem;
    border-radius: var(--radius-md);
    font-size: var(--font-small);
    font-weight: 500;
    text-decoration: none;
    transition:
      background-color var(--duration-base) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .sticky-btn:active { transform: scale(0.97); }

  .sticky-btn--call {
    background-color: var(--color-accent);
    color: #fff;
  }

  .sticky-btn--call:active { background-color: var(--color-accent-hover); }

  .sticky-btn--form {
    background-color: rgba(255,255,255,0.1);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.15);
  }

  @media (prefers-reduced-motion: reduce) {
    .sticky-cta {
      transition: none;
    }
    .sticky-btn:active {
      transform: none;
    }
  }
</style>

<script>
  const bar = document.getElementById('sticky-cta');
  if (bar) {
    let lastY = window.scrollY;

    window.addEventListener('scroll', () => {
      const currentY = window.scrollY;
      if (currentY < 100) {
        bar.classList.remove('hidden');
      } else if (currentY < lastY) {
        // Scrolling up — hide
        bar.classList.add('hidden');
      } else {
        // Scrolling down — show
        bar.classList.remove('hidden');
      }
      lastY = currentY;
    }, { passive: true });
  }
</script>
