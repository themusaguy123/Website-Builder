---
const appliances = [
  'Refrigerator',
  'Washing Machine',
  'Dryer',
  'Dishwasher',
  'Oven / Range',
  'Cooktop / Stove',
  'Garbage Disposal',
  'Ice Maker',
  'Microwave',
  'Other',
];

const phones = [
  { state: 'VA', number: '703-866-7776', href: 'tel:+17038667776' },
  { state: 'MD', number: '301-907-6666', href: 'tel:+13019076666' },
  { state: 'DC', number: '202-783-2055', href: 'tel:+12027832055' },
];
---

<section class="section booking-section" id="booking">
  <div class="container">
    <div class="booking-wrap reveal">
      <div class="booking-text">
        <h2>Request a Callback</h2>
        <p>
          Tell us what's broken and we'll call you back within 30 minutes.
          Free service call when we complete the repair.
        </p>
        <div class="booking-phones">
          <p class="booking-phones-label">Prefer to call us directly?</p>
          {phones.map((p) => (
            <a href={p.href} class="booking-phone-link">
              <span class="booking-phone-state">{p.state}</span>
              <span class="booking-phone-num">{p.number}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="booking-form-wrap">
        <!-- Step 1: appliance picker -->
        <div class="form-step" id="form-step-1" aria-label="Step 1: Choose your appliance">
          <p class="form-step-label">
            <span class="step-pill">Step 1 of 2</span>
            What needs repairing?
          </p>
          <div class="appliance-grid" role="group" aria-label="Select appliance type">
            {appliances.map((a) => (
              <button
                type="button"
                class="appliance-chip"
                data-appliance={a}
                aria-pressed="false"
              >
                {a}
              </button>
            ))}
          </div>
        </div>

        <!-- Step 2: contact form -->
        <div class="form-step form-step--hidden" id="form-step-2" aria-label="Step 2: Your contact information" aria-hidden="true">
          <div class="form-step-2-header">
            <button type="button" class="back-btn" id="form-back">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M19 12H5M12 19l-7-7 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Back
            </button>
            <p class="form-step-label">
              <span class="step-pill">Step 2 of 2</span>
              Your contact info
            </p>
          </div>
          <div class="selected-appliance-tag" id="selected-appliance-display"></div>

          <form
            id="booking-form"
            action="https://formspree.io/f/YOUR_FORM_ID"
            method="POST"
            novalidate
          >
            <input type="hidden" name="appliance" id="appliance-hidden" />
            <input type="hidden" name="_subject" value="New Appliance Repair Request — DMV Appliance Repair" />
            <input type="hidden" name="_replyto" value="" />

            <div class="form-fields">
              <div class="form-field">
                <label for="field-name" class="form-label">Your name <span class="required" aria-label="required">*</span></label>
                <input
                  type="text"
                  id="field-name"
                  name="name"
                  class="form-input"
                  autocomplete="name"
                  required
                  aria-required="true"
                />
              </div>

              <div class="form-field">
                <label for="field-phone" class="form-label">Phone number <span class="required" aria-label="required">*</span></label>
                <input
                  type="tel"
                  id="field-phone"
                  name="phone"
                  class="form-input"
                  autocomplete="tel"
                  required
                  aria-required="true"
                />
              </div>

              <div class="form-field">
                <label for="field-zip" class="form-label">Zip code <span class="required" aria-label="required">*</span></label>
                <input
                  type="text"
                  id="field-zip"
                  name="zip"
                  class="form-input"
                  inputmode="numeric"
                  pattern="[0-9]{5}"
                  maxlength="5"
                  autocomplete="postal-code"
                  required
                  aria-required="true"
                />
              </div>

              <div class="form-field form-field--full">
                <label for="field-description" class="form-label">Briefly describe the issue <span class="form-label-optional">(optional)</span></label>
                <textarea
                  id="field-description"
                  name="description"
                  class="form-input form-textarea"
                  rows="3"
                  placeholder="e.g. Fridge not cooling, dishwasher not draining, dryer takes two cycles…"
                ></textarea>
              </div>

              <div class="form-field form-field--full">
                <button type="submit" class="btn btn--primary form-submit" id="form-submit-btn">
                  Request a Callback
                </button>
                <p class="form-note">We'll call you back within 30 minutes during business hours.</p>
              </div>
            </div>
          </form>
        </div>

        <!-- Success state -->
        <div class="form-success form-step--hidden" id="form-success" aria-hidden="true">
          <div class="success-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <polyline points="22 4 12 14.01 9 11.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Request received!</h3>
          <p>We'll call you back within 30 minutes during business hours. If it's urgent, call us directly:</p>
          <div class="success-phones">
            {phones.map((p) => (
              <a href={p.href} class="booking-phone-link">
                <span class="booking-phone-state">{p.state}</span>
                <span class="booking-phone-num">{p.number}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .booking-section {
    background-color: var(--color-bg);
    border-top: 1px solid var(--color-border);
  }

  .booking-wrap {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: var(--space-12);
    align-items: start;
  }

  @media (max-width: 860px) {
    .booking-wrap {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  .booking-text h2 { margin-bottom: var(--space-3); }

  .booking-text > p {
    font-size: var(--font-body);
    color: var(--color-ink-muted);
    margin-bottom: var(--space-6);
  }

  .booking-phones { margin-top: var(--space-6); }

  .booking-phones-label {
    font-size: var(--font-xs);
    font-weight: 500;
    color: var(--color-ink-soft);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-3);
    max-width: none;
  }

  .booking-phone-link {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    text-decoration: none;
    padding: var(--space-2) 0;
    transition: opacity var(--duration-base) var(--ease-out);
  }

  @media (hover: hover) and (pointer: fine) {
    .booking-phone-link:hover { opacity: 0.75; }
  }

  .booking-phone-state {
    font-size: var(--font-xs);
    font-weight: 600;
    color: var(--color-ink-soft);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    min-width: 2.5ch;
  }

  .booking-phone-num {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-ink);
  }

  /* Form wrap */
  .booking-form-wrap {
    background-color: var(--color-bg-soft);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    position: relative;
    min-height: 300px;
  }

  /* Form steps — fade transition (no layout shift) */
  .form-step {
    transition:
      opacity var(--duration-base) var(--ease-out);
  }

  .form-step--hidden {
    display: none;
    opacity: 0;
  }

  .form-step-label {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--font-body);
    font-weight: 500;
    color: var(--color-ink);
    margin-bottom: var(--space-5);
    max-width: none;
  }

  .step-pill {
    font-size: var(--font-xs);
    font-weight: 600;
    background-color: var(--color-accent-soft);
    color: var(--color-accent-hover);
    border-radius: var(--radius-pill);
    padding: 0.2rem 0.6rem;
    flex-shrink: 0;
  }

  /* Appliance grid */
  .appliance-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2);
  }

  @media (max-width: 480px) {
    .appliance-grid { grid-template-columns: 1fr; }
  }

  .appliance-chip {
    padding: 0.625rem 0.875rem;
    border-radius: var(--radius-md);
    background-color: #fff;
    border: 1.5px solid var(--color-border);
    font-size: var(--font-small);
    font-weight: 500;
    color: var(--color-ink-muted);
    cursor: pointer;
    text-align: left;
    transition:
      background-color var(--duration-base) var(--ease-out),
      color var(--duration-base) var(--ease-out),
      border-color var(--duration-base) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  @media (hover: hover) and (pointer: fine) {
    .appliance-chip:hover {
      background-color: var(--color-accent-soft);
      border-color: var(--color-accent-soft);
      color: var(--color-ink);
    }
  }

  .appliance-chip:active {
    transform: scale(0.97);
    background-color: var(--color-accent-soft);
  }

  .appliance-chip[aria-pressed="true"] {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  /* Step 2 header */
  .form-step-2-header {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .form-step-2-header .form-step-label { margin-bottom: 0; }

  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    background: none;
    border: none;
    cursor: pointer;
    font-size: var(--font-small);
    color: var(--color-ink-muted);
    padding: 0.25rem 0;
    flex-shrink: 0;
    transition:
      color var(--duration-base) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .back-btn:active { transform: scale(0.96); }

  @media (hover: hover) and (pointer: fine) {
    .back-btn:hover { color: var(--color-ink); }
  }

  .selected-appliance-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.625rem;
    background-color: var(--color-accent-soft);
    color: var(--color-accent-hover);
    border-radius: var(--radius-pill);
    font-size: var(--font-xs);
    font-weight: 600;
    margin-bottom: var(--space-5);
    min-height: 1.5rem;
  }

  /* Form fields */
  .form-fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  @media (max-width: 540px) {
    .form-fields { grid-template-columns: 1fr; }
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .form-field--full {
    grid-column: 1 / -1;
  }

  .form-label {
    font-size: var(--font-small);
    font-weight: 500;
    color: var(--color-ink);
    max-width: none;
  }

  .form-label-optional {
    color: var(--color-ink-soft);
    font-weight: 400;
  }

  .required { color: var(--color-accent); }

  .form-input {
    padding: 0.625rem 0.875rem;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    background-color: #fff;
    font-size: var(--font-body);
    color: var(--color-ink);
    transition:
      border-color var(--duration-base) var(--ease-out),
      box-shadow var(--duration-base) var(--ease-out);
    width: 100%;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(255, 107, 26, 0.12);
  }

  .form-input:invalid:not(:placeholder-shown) {
    border-color: #D94040;
  }

  .form-textarea { resize: vertical; min-height: 80px; }

  .form-submit { width: 100%; justify-content: center; }

  .form-note {
    font-size: var(--font-xs);
    color: var(--color-ink-soft);
    text-align: center;
    max-width: none;
    margin-top: var(--space-1);
  }

  /* Success */
  .form-success {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-4);
    padding: var(--space-6) 0;
  }

  .success-icon {
    width: 52px;
    height: 52px;
    background-color: #ECFDF5;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-success);
  }

  .form-success h3 {
    font-size: var(--font-h3);
    color: var(--color-ink);
  }

  .form-success p {
    font-size: var(--font-small);
    color: var(--color-ink-muted);
    max-width: 38ch;
    margin-inline: auto;
  }

  .success-phones {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    align-items: flex-start;
    width: 100%;
    max-width: 22ch;
  }
</style>

<script>
  const step1 = document.getElementById('form-step-1');
  const step2 = document.getElementById('form-step-2');
  const successEl = document.getElementById('form-success');
  const applianceHidden = document.getElementById('appliance-hidden') as HTMLInputElement | null;
  const applianceDisplay = document.getElementById('selected-appliance-display');
  const backBtn = document.getElementById('form-back');
  const form = document.getElementById('booking-form') as HTMLFormElement | null;

  function showStep(el: HTMLElement | null) {
    el?.classList.remove('form-step--hidden');
    el?.removeAttribute('aria-hidden');
    // Trigger opacity transition after display is set
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        if (el) el.style.opacity = '1';
      });
    });
  }

  function hideStep(el: HTMLElement | null, cb?: () => void) {
    if (!el) return;
    el.style.opacity = '0';
    setTimeout(() => {
      el.classList.add('form-step--hidden');
      el.setAttribute('aria-hidden', 'true');
      el.style.opacity = '';
      cb?.();
    }, 200);
  }

  // Appliance chip click
  document.querySelectorAll<HTMLButtonElement>('.appliance-chip').forEach((chip) => {
    chip.addEventListener('click', () => {
      const appliance = chip.dataset.appliance ?? '';
      if (applianceHidden) applianceHidden.value = appliance;
      if (applianceDisplay) applianceDisplay.textContent = appliance;

      hideStep(step1, () => showStep(step2));
    });
  });

  // Back button
  backBtn?.addEventListener('click', () => {
    hideStep(step2, () => showStep(step1));
  });

  // Form submit
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = document.getElementById('form-submit-btn') as HTMLButtonElement | null;
    if (submitBtn) {
      submitBtn.textContent = 'Sending…';
      submitBtn.disabled = true;
    }

    try {
      const data = new FormData(form);
      const res = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        hideStep(step2, () => showStep(successEl));
      } else {
        if (submitBtn) {
          submitBtn.textContent = 'Request a Callback';
          submitBtn.disabled = false;
        }
        alert('Something went wrong. Please call us directly or try again.');
      }
    } catch {
      if (submitBtn) {
        submitBtn.textContent = 'Request a Callback';
        submitBtn.disabled = false;
      }
      alert('Something went wrong. Please call us directly.');
    }
  });
</script>
