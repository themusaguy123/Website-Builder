---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import TrustBar from '@/components/TrustBar.astro';
import ServiceGrid from '@/components/ServiceGrid.astro';
import HonestyCallout from '@/components/HonestyCallout.astro';
import ReviewsGrid from '@/components/ReviewsGrid.astro';
import WhyChooseUs from '@/components/WhyChooseUs.astro';
import ServiceAreas from '@/components/ServiceAreas.astro';
import BookingForm from '@/components/BookingForm.astro';
import FAQ from '@/components/FAQ.astro';
import StickyMobileCTA from '@/components/StickyMobileCTA.astro';
import BrandLogoStrip from '@/components/BrandLogoStrip.astro';

const homeFAQ = [
  {
    q: 'Do you charge extra for weekend or evening appliance repair?',
    a: 'No — same rate every day of the week, including evenings, weekends, and holidays. The price we quote is what you pay.',
  },
  {
    q: 'How does the free service call work?',
    a: 'The service call fee is waived when we do the repair. If you hear the diagnosis and decide not to move forward, there\'s a visit fee. Either way, we tell you exactly what\'s wrong and what it costs before we touch anything.',
  },
  {
    q: 'Do you carry parts on the truck?',
    a: 'Yes — we keep the parts we use most often stocked on the truck. That\'s how most repairs get done in one visit. If we need something less common, we\'ll order it and come back, usually within a day or two.',
  },
  {
    q: 'What brands do you service?',
    a: 'All major brands including Samsung, LG, Whirlpool, GE, Kenmore, Maytag, Frigidaire, Bosch, KitchenAid, Electrolux, Jenn-Air, Viking, Sub-Zero, Wolf, Thermador, Miele, and many others.',
  },
  {
    q: 'What areas do you serve?',
    a: 'All of Northern Virginia (Fairfax, Loudoun, Prince William, and Arlington counties), Maryland (Montgomery, Prince George\'s, and Howard counties), and every neighborhood in Washington D.C.',
  },
  {
    q: 'Is there a warranty on repairs?',
    a: 'Yes. Every repair comes with a warranty on parts and labor. If something\'s not right after we leave, we come back and sort it out.',
  },
];
---

<BaseLayout
  title="DMV Appliance Repair | Same-Day Service in Virginia, Maryland & DC"
  description="Trusted appliance repair across the DMV since 2007. Same-day service 7 days a week, no weekend fees. We carry parts on the truck so most repairs are done in one visit. Call now."
  schemaType="home"
>
  <Hero
    variant="home"
    headline="The Repair Tech Who Tells You When It's Not Worth Fixing"
    subheadline="Pir has been repairing appliances across the DMV since 2007. Same-day service, parts on the truck, flat rates — and if the repair doesn't make financial sense, he'll tell you upfront."
    badge="Same-day service · 7 days a week"
  />

  <TrustBar />

  <HonestyCallout />

  <ServiceGrid />

  <ReviewsGrid />

  <WhyChooseUs />

  <BrandLogoStrip />

  <ServiceAreas />

  <BookingForm />

  <FAQ items={homeFAQ} heading="Common Questions" />

  <StickyMobileCTA />
</BaseLayout>
